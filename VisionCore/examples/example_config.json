{
    "vision_model": {
        "file_path": "C:\\Users\\RoboticsTeam\\Desktop\\VisionCore\\VisionCore-Deploy\\YoloModels\\pytorch\\nano\\dummy_openvino_model",
        "task": "detect",
        "num_classes": 80,
        "input_size": [640, 640],
        "min_conf": 0.5,
        "margin": 10,
        "output": {
            "format": "raw",
            "layout": "anchors_first",
            "box_format": "cxcywh",
            "score_mode": "multi_class",
            "scores_are_logits": false,
            "apply_software_nms": true,
            "nms_iou": 0.45,
            "quantization": "none"
        },
        "input": {
            "layout": "nhwc",
            "dtype": "uint8",
            "letterbox": true,
            "pad_value": 114,
            "normalize": false
        }
    },
    "unit": "meter",
    "debug_mode": true,
    "dbscan": {
        "elipson": 0.3,
        "min_samples": 3
    },
    "distance_threshold": 0.5,
    "stale_threshold": 1.0,
    "record_mode": true,
    "record_dir": "VideoRecordings",
    "auto_opt": true,
    "log_level": "INFO",
    "log_file": "Outputs/log.txt",
    "camera_configs": {
        "defualt_cam": {
            "source": 0,
            "pipeline": "object_detection",
            "fps_cap": 30,
            "yaw": 0,
            "pitch": 0,
            "height": 1.0,
            "x": 0,
            "y": 0,
            "calibration": {
                "distance": 0.0,
                "game_piece_size": 0.0,
                "size": 0,
                "fov": 0
            }
        }
    },
    "plugins": {
        "trackers": [
            "object_tracker",
            "fuel",
            "path_planner"
        ],
        "utilities": [
            "video_recorder"
        ]
    }
}
